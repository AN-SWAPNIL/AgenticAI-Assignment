# ─── Local (read by the frontend + convex dev CLI) ──────────────────
# After running `npx convex dev --configure`, copy the values it prints:
CONVEX_DEPLOYMENT=dev:<your-deployment-slug>
VITE_CONVEX_URL=https://<your-deployment-slug>.convex.cloud


DAYTONA_API_KEY=dtn_...
GEMINI_API_KEY=AIza...

# ─── Convex deployment env (NOT read from this file) ────────────────
# Convex Node actions read process.env from the Convex runtime, not .env.
# Set these with `npx convex env set <NAME> "<value>"`:
#   DAYTONA_API_KEY   — https://app.daytona.io/  → Settings → API Keys
#   GEMINI_API_KEY    — https://aistudio.google.com/app/apikey
#
# Example:
#   npx convex env set DAYTONA_API_KEY "dtn_..."
#   npx convex env set GEMINI_API_KEY  "AIza..."
