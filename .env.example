# Local env (frontend + convex dev CLI)
# After `npx convex dev --configure`, copy these from the CLI output.
CONVEX_DEPLOYMENT=dev:<your-deployment-slug>
VITE_CONVEX_URL=https://<your-deployment-slug>.convex.cloud

# Primary provider key (Google Gemini — default model)
DAYTONA_API_KEY=dtn_...
GEMINI_API_KEY=AIza...
TAVILY_API_KEY=tvly-...

# Optional: additional LLM provider keys (enable Claude and more OpenAI model options)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: Daytona snapshot for faster cold starts (~5s vs ~30s)
# Run `node scripts/create-snapshot.mjs` once, then paste the returned name here.
DAYTONA_SNAPSHOT=

# Convex deployment env (source of truth for actions/orchestrator/daemon)
# Set each variable with:
#   npx convex env set DAYTONA_API_KEY "dtn_..."
#   npx convex env set GEMINI_API_KEY "AIza..."
#   npx convex env set TAVILY_API_KEY "tvly-..."
#   npx convex env set ANTHROPIC_API_KEY "sk-ant-..."   # optional
#   npx convex env set OPENAI_API_KEY "sk-..."           # optional
#   npx convex env set DAYTONA_SNAPSHOT "agentic-runtime-v1"  # optional
