{
  "name": "agenticai-assignment",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Isolated agent chatbot — Convex control plane + Daytona execution plane + Pi Agent runtime",
  "scripts": {
    "bundle:agent": "node scripts/bundle-runtime.mjs",
    "predev": "npm run bundle:agent",
    "prebuild": "npm run bundle:agent",
    "dev": "concurrently -n convex,web -c blue,green \"npm run dev:convex\" \"npm run dev:web\"",
    "dev:convex": "convex dev",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "convex codegen && tsc -b && tsc -p agent/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css,html}\""
  },
  "dependencies": {
    "@daytona/sdk": "^0.167.0",
    "clsx": "^2.1.1",
    "convex": "^1.35.1",
    "date-fns": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "latest",
    "@mariozechner/pi-ai": "latest",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
